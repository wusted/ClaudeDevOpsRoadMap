# Diego's per-module repositories live here as independent git repos.
# Exclude their contents from the parent template repo.
repos/*
!repos/README.md
!repos/.gitkeep

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Local Claude session state (auto memory lives in ~/.claude, not here)
.claude/settings.local.json
